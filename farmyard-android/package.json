{
  "name": "farmyard-android",
  "version": "1.0.0",
  "private": true,
  "description": "FarmYard Android packaging workspace using Capacitor.",
  "scripts": {
    "serve": "serve web",
    "cap:copy": "npx cap copy android",
    "cap:sync": "npx cap sync android",
    "cap:add:android": "npx cap add android",
    "cap:open:android": "npx cap open android",
    "cap:doctor": "npx cap doctor",
    "cap:assets": "npx capacitor-assets generate --android --iconBackgroundColor '#234a2f' --iconBackgroundColorDark '#234a2f'"
  },
  "dependencies": {
    "@capacitor/app": "latest",
    "@capacitor/browser": "latest",
    "@capacitor/core": "latest",
    "@capacitor/keyboard": "latest",
    "@capacitor/status-bar": "latest"
  },
  "devDependencies": {
    "@capacitor/android": "latest",
    "@capacitor/assets": "latest",
    "@capacitor/cli": "latest",
    "serve": "latest"
  }
}

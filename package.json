{
  "name": "farmyard-app",
  "version": "1.0.0",
  "private": true,
  "description": "FarmYard static web app packaged for Android and iPhone with Capacitor.",
  "scripts": {
    "serve": "serve .",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:doctor": "npx cap doctor",
    "cap:assets": "npx capacitor-assets generate --iconBackgroundColor '#234a2f' --iconBackgroundColorDark '#234a2f'"
  },
  "dependencies": {
    "@capacitor/app": "latest",
    "@capacitor/browser": "latest",
    "@capacitor/core": "latest",
    "@capacitor/keyboard": "latest",
    "@capacitor/status-bar": "latest"
  },
  "devDependencies": {
    "@capacitor/android": "latest",
    "@capacitor/assets": "latest",
    "@capacitor/cli": "latest",
    "@capacitor/ios": "latest",
    "serve": "latest"
  }
}

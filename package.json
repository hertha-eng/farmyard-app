{
  "name": "farmyard-app",
  "version": "1.0.0",
  "private": true,
  "description": "FarmYard static web app packaged for Android and iPhone with Capacitor.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "serve": "serve .",
    "launch:audit": "bash scripts/launch-audit.sh",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:doctor": "npx cap doctor",
    "cap:assets": "npx capacitor-assets generate --iconBackgroundColor '#234a2f' --iconBackgroundColorDark '#234a2f'"
  },
  "dependencies": {
    "@capacitor/app": "8.0.0",
    "@capacitor/browser": "8.0.0",
    "@capacitor/core": "8.0.0",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/status-bar": "8.0.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@capacitor/android": "8.0.0",
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.0.0",
    "@capacitor/ios": "8.0.0",
    "serve": "14.2.4"
  }
}

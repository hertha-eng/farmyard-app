{
  "name": "farmyard-ios",
  "version": "1.0.0",
  "private": true,
  "description": "FarmYard iPhone packaging workspace using Capacitor.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "serve": "serve web",
    "launch:audit": "bash ../scripts/launch-audit.sh ios",
    "cap:copy": "npx cap copy ios",
    "cap:sync": "npx cap sync ios",
    "cap:add:ios": "npx cap add ios",
    "cap:open:ios": "npx cap open ios",
    "cap:doctor": "npx cap doctor",
    "cap:assets": "npx capacitor-assets generate --ios --iconBackgroundColor '#234a2f' --iconBackgroundColorDark '#234a2f'"
  },
  "dependencies": {
    "@capacitor/app": "8.0.0",
    "@capacitor/browser": "8.0.0",
    "@capacitor/core": "8.0.0",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/status-bar": "8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.0.0",
    "@capacitor/ios": "8.0.0",
    "serve": "14.2.4"
  }
}
